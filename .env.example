# Application Configuration
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 统一环境开关（只看 NODE_ENV）：
# - production：禁用 /api/test-* 测试端点，小程序关闭请求调试日志
# - development：启用 /api/test-* 测试端点，小程序开启请求调试日志

# CloudBase SQL Configuration
CLOUDBASE_ID=your_cloudbase_env_id_here
CLOUDBASE_SECRET_ID=your_cloudbase_secret_id_here
CLOUDBASE_SECRET_KEY=your_cloudbase_secret_key_here
CLOUDBASE_BUCKET_ID=your_cloudbase_bucket_id_here
CLOUDBASE_STORAGE_DOMAIN=https://your-cloudbase-storage-domain.tcb.qcloud.la
NEXT_PUBLIC_CLOUDBASE_STORAGE_DOMAIN=https://your-cloudbase-storage-domain.tcb.qcloud.la
CLOUDBASE_SQL_DB_NAME=photo
CLOUDBASE_SQL_REGION=ap-guangzhou
MINIPROGRAM_CLOUDRUN_SERVICE=your_cloudrun_service_name_here
# 可选：不填则默认回退使用 APP_URL
# MINIPROGRAM_CLOUDRUN_BASE_URL=https://your-cloudrun-public-domain.example.com

# Tencent Map (腾讯地图) Configuration
# 前端 JS GL 地图 Key：只给浏览器地图脚本使用
TMAP_JS_KEY=your_tmap_javascript_gl_key_here
TMAP_KEY=your_tmap_javascript_gl_key_here
NEXT_PUBLIC_TMAP_KEY=your_tmap_javascript_gl_key_here
# 服务端 WebService Key：只给 /api/tencent-map/* 路由使用
# 注意：不要再复用前端 JS Key；服务端调用请使用 WebService 专用 Key，
# 并在腾讯位置服务控制台配置「授权IP」或「签名校验」。
TMAP_SERVER_KEY=your_tmap_webservice_key_here
TMAP_WEBSERVICE_KEY=your_tmap_webservice_key_here

# Cron / Maintenance Configuration
CRON_SECRET=your_cron_secret_here
MAINTENANCE_TOKEN=your_maintenance_token_here

# Slider Captcha Configuration (Server Only)
CAPTCHA_SECRET_KEY=your_random_hex_or_base64_secret_at_least_32_chars

# 微信小程序审核隐藏开关（true: 隐藏约拍入口，false: 显示约拍入口）
HIDE_AUDIT=false
